{
  "buildCommand": "npm install && npx vite build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "framework": null,
  "rootDirectory": "frontend",
  "rewrites": [
    { "source": "/preview.html", "destination": "/preview.html" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
